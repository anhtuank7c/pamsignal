# pamsignal configuration
# /etc/pamsignal/pamsignal.conf
#
# All values shown are defaults. Uncomment and change as needed.
# Reload without restart: sudo systemctl reload pamsignal
#
# This file may contain alert credentials.
# Recommended permissions: root:pamsignal 0640

# Brute-force detection
# fail_threshold = 5
# fail_window_sec = 300
# max_tracked_ips = 256

# --- Context tags (optional) ---
# Add metadata to your alerts to easily identify the server environment
# provider = aws
# service_name = web-api

# Alert rate limiting
# alert_cooldown_sec = 60

# --- Alert channels (optional, best-effort) ---
# Only configure the channels you use.
# Alerts are fire-and-forget — failures won't break monitoring.

# Telegram
# telegram_bot_token = <bot_token>
# telegram_chat_id = <chat_id>

# Slack
# slack_webhook_url = <webhook_url>

# Microsoft Teams
# teams_webhook_url = <webhook_url>

# WhatsApp (Meta Cloud API)
# whatsapp_access_token = <access_token>
# whatsapp_phone_number_id = <phone_number_id>
# whatsapp_recipient = <recipient_number>

# Discord
# discord_webhook_url = <webhook_url>

# Custom webhook (receives JSON POST, see docs/alerts.md)
# webhook_url = <webhook_url>
