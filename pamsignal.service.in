[Unit]
Description=PAMSignal - Real-time PAM login monitor
Documentation=https://github.com/anhtuank7c/pamsignal
After=systemd-journald.service

[Service]
# Type=notify: the daemon explicitly signals readiness via sd_notify(READY=1)
# AFTER ps_journal_watch_init() succeeds. systemd considers the unit "active"
# only at that point — not the moment fork() returns — so Wants=/After= chains
# resolve correctly and `systemctl status` doesn't lie about state during the
# brief startup window.
#
# WatchdogSec=30s + sd_notify(WATCHDOG=1) on every main-loop iteration: if
# sd_journal_wait wedges (kernel bug, journal corruption) the daemon is
# auto-restarted instead of silently going dark on auth events.
Type=notify
NotifyAccess=main
WatchdogSec=30s
ExecStart=@bindir@/pamsignal --foreground
User=pamsignal
Group=pamsignal
SupplementaryGroups=systemd-journal
Restart=on-failure
RestartSec=5
ExecReload=/bin/kill -HUP $MAINPID

# Minimal PATH for the alert dispatch path. The daemon execs curl by absolute
# path (/usr/bin/curl) but clearenv()s the child anyway; this Environment=
# closes the gap if the binary is launched directly (not via this unit).
Environment=PATH=/usr/bin:/bin

# Runtime directory for PID file (/run/pamsignal/)
RuntimeDirectory=pamsignal
ConfigurationDirectory=pamsignal

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
MemoryDenyWriteExecute=yes
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
PrivateDevices=yes
CapabilityBoundingSet=
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

[Install]
WantedBy=multi-user.target
