version=4

# uscan format 4. Run `uscan --report` from this directory (or
# `uscan --verbose --no-download` for a dry run) to see what upstream
# versions Debian's automated trackers detect.
#
# GitHub serves a tag listing at /tags. Each release shows up as both
# `vX.Y.Z.tar.gz` and `X.Y.Z.tar.gz`; we accept either by making the `v`
# optional. The filenamemangle rewrites the URL-derived filename
# `vX.Y.Z.tar.gz` (or `X.Y.Z.tar.gz`) to the Debian-conventional
# `pamsignal_X.Y.Z.orig.tar.gz` so `uscan` can drop the orig tarball
# straight into the parent directory at the right name.
#
# uversionmangle is a no-op here (we use SemVer-clean upstream tags) but
# is the standard place to strip release-candidate suffixes etc. should
# we ever ship a "v0.3.0-rc1" tag.

opts="\
filenamemangle=s|.+/v?(\d\S+)\.tar\.gz|pamsignal-$1.tar.gz|,\
uversionmangle=s/(\d)[_\.\-\+]?(RC|rc|pre|dev|beta|alpha)\.?(\d*)$/$1~$2$3/" \
  https://github.com/anhtuank7c/pamsignal/tags \
  (?:.*/)?v?(\d\S+)\.tar\.gz
