# dpkg-buildpackage / debhelper byproducts. tests/scenario.sh and a
# manual `dpkg-buildpackage -us -uc -b` both produce these under debian/.
# Tracked debian/ files (changelog, control, copyright, postinst, postrm,
# prerm, rules, source/format) are not affected — these patterns only
# match the auto-generated state.
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/pamsignal/
debian/*.substvars
debian/*.debhelper.log
debian/*.debhelper
